<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE config SYSTEM "http://www.matsim.org/files/dtd/config_v2.dtd">
<config>

<!-- ======================================================================= -->
<!-- BASELINE MODEL: Original UrbanEV-v2 (Parishwad et al. 2026)             -->
<!-- No en-route charging, no PHEV, no SoC persistence, no reliability       -->
<!-- Queue traffic dynamics + FastAStarLandmarks routing                      -->
<!-- ======================================================================= -->

<!-- ======================================================================= -->
<!-- Global Settings                                                         -->
<!-- ======================================================================= -->
<module name="global">
    <param name="coordinateSystem" value="EPSG:26985"/>
    <param name="randomSeed" value="42"/>
    <param name="numberOfThreads" value="14"/>
</module>

<!-- ======================================================================= -->
<!-- Network                                                                 -->
<!-- ======================================================================= -->
<module name="network">
    <param name="inputNetworkFile" value="../input/maryland-dc-ev-network.xml.gz"/>
</module>

<!-- ======================================================================= -->
<!-- Plans                                                                   -->
<!-- ======================================================================= -->
<module name="plans">
    <param name="inputPlansFile" value="../input/plans_maryland_ev.xml.gz"/>
    <param name="removingUnnecessaryPlanAttributes" value="true"/>
</module>

<!-- ======================================================================= -->
<!-- Vehicles                                                                -->
<!-- ======================================================================= -->
<module name="vehicles">
    <param name="vehiclesFile" value="../input/vehicletypes.xml"/>
</module>

<!-- ======================================================================= -->
<!-- EV contrib                                                              -->
<!-- ======================================================================= -->
<module name="ev">
    <param name="chargersFile" value="../input/chargers.xml"/>
    <param name="vehiclesFile" value="../input/electric_vehicles.xml"/>
    <param name="chargeTimeStep" value="5"/>
</module>

<!-- ======================================================================= -->
<!-- Transit (disabled)                                                      -->
<!-- ======================================================================= -->
<module name="transit">
    <param name="useTransit" value="false"/>
</module>

<!-- ======================================================================= -->
<!-- Controler                                                               -->
<!-- ======================================================================= -->
<module name="controler">
    <param name="outputDirectory" value="../output_baseline/"/>
    <param name="firstIteration" value="0"/>
    <param name="lastIteration" value="60"/>
    <param name="writeEventsInterval" value="5"/>
    <param name="writePlansInterval" value="5"/>
    <param name="writeSnapshotsInterval" value="10"/>
    <param name="mobsim" value="qsim"/>
    <param name="routingAlgorithmType" value="FastAStarLandmarks"/>
    <param name="runId" value="maryland_ev_baseline"/>
    <param name="overwriteFiles" value="deleteDirectoryIfExists"/>
</module>

<!-- ======================================================================= -->
<!-- QSim                                                                    -->
<!-- ======================================================================= -->
<module name="qsim">
    <param name="startTime" value="00:00:00"/>
    <param name="endTime" value="54:00:00"/>
    <param name="flowCapacityFactor" value="1.0"/>
    <param name="storageCapacityFactor" value="1.0"/>
    <param name="numberOfThreads" value="14"/>
    <param name="mainMode" value="car"/>
    <param name="vehiclesSource" value="modeVehicleTypesFromVehiclesData"/>
    <param name="linkDynamics" value="FIFO"/>
    <param name="trafficDynamics" value="queue"/>
    <param name="stuckTime" value="900"/>
    <param name="removeStuckVehicles" value="true"/>
    <param name="insertingWaitingVehiclesBeforeDrivingVehicles" value="true"/>
    <param name="snapshotperiod" value="00:15:00"/>
    <param name="simStarttimeInterpretation" value="maxOfStarttimeAndEarliestActivityEnd"/>
    <param name="vehicleBehavior" value="teleport"/>
</module>

<!-- ======================================================================= -->
<!-- Parallel Event Handling                                                 -->
<!-- ======================================================================= -->
<module name="parallelEventHandling">
    <param name="numberOfThreads" value="12"/>
    <param name="estimatedNumberOfEvents" value="200000000"/>
    <param name="synchronizeOnSimSteps" value="true"/>
</module>

<!-- ======================================================================= -->
<!-- planCalcScore (Charypar-Nagel Scoring)                                  -->
<!-- ======================================================================= -->
<module name="planCalcScore">
    <param name="learningRate" value="1.0"/>
    <param name="BrainExpBeta" value="1.0"/>
    <param name="fractionOfIterationsToStartScoreMSA" value="0.80"/>
    <param name="writeExperiencedPlans" value="true"/>

    <parameterset type="scoringParameters">
        <param name="lateArrival" value="-18.0"/>
        <param name="earlyDeparture" value="-0.0"/>
        <param name="performing" value="6.0"/>
        <param name="waiting" value="-0.0"/>
        <param name="waitingPt" value="-2.0"/>
        <param name="marginalUtilityOfMoney" value="1.0"/>
        <param name="utilityOfLineSwitch" value="-1.0"/>

        <!-- car -->
        <parameterset type="modeParams">
            <param name="mode" value="car"/>
            <param name="constant" value="-1.0"/>
            <param name="marginalUtilityOfTraveling_util_hr" value="-6.0"/>
            <param name="marginalUtilityOfDistance_util_m" value="-0.0002"/>
            <param name="monetaryDistanceRate" value="-0.00015"/>
        </parameterset>

        <!-- walk -->
        <parameterset type="modeParams">
            <param name="mode" value="walk"/>
            <param name="constant" value="0.0"/>
            <param name="marginalUtilityOfTraveling_util_hr" value="-12.0"/>
            <param name="marginalUtilityOfDistance_util_m" value="0.0"/>
            <param name="monetaryDistanceRate" value="0.0"/>
        </parameterset>

        <!-- pt -->
        <parameterset type="modeParams">
            <param name="mode" value="pt"/>
            <param name="constant" value="0.0"/>
            <param name="marginalUtilityOfTraveling_util_hr" value="-6.0"/>
            <param name="marginalUtilityOfDistance_util_m" value="0.0"/>
            <param name="monetaryDistanceRate" value="0.0"/>
        </parameterset>

        <!-- home -->
        <parameterset type="activityParams">
            <param name="activityType" value="home"/>
            <param name="typicalDuration" value="12:00:00"/>
            <param name="minimalDuration" value="01:00:00"/>
            <param name="priority" value="1"/>
        </parameterset>

        <!-- work -->
        <parameterset type="activityParams">
            <param name="activityType" value="work"/>
            <param name="typicalDuration" value="08:00:00"/>
            <param name="minimalDuration" value="01:00:00"/>
            <param name="openingTime" value="06:00:00"/>
            <param name="closingTime" value="22:00:00"/>
            <param name="latestStartTime" value="10:00:00"/>
            <param name="earliestEndTime" value="15:00:00"/>
            <param name="priority" value="1"/>
        </parameterset>

        <!-- school -->
        <parameterset type="activityParams">
            <param name="activityType" value="school"/>
            <param name="typicalDuration" value="06:00:00"/>
            <param name="minimalDuration" value="01:00:00"/>
            <param name="openingTime" value="07:00:00"/>
            <param name="closingTime" value="18:00:00"/>
            <param name="latestStartTime" value="09:00:00"/>
            <param name="priority" value="1"/>
        </parameterset>

        <!-- other -->
        <parameterset type="activityParams">
            <param name="activityType" value="other"/>
            <param name="typicalDuration" value="01:30:00"/>
            <param name="minimalDuration" value="00:15:00"/>
            <param name="priority" value="1"/>
        </parameterset>

        <!-- home charging -->
        <parameterset type="activityParams">
            <param name="activityType" value="home charging"/>
            <param name="typicalDuration" value="08:00:00"/>
            <param name="minimalDuration" value="00:30:00"/>
            <param name="priority" value="1"/>
            <param name="scoringThisActivityAtAll" value="true"/>
        </parameterset>

        <!-- work charging -->
        <parameterset type="activityParams">
            <param name="activityType" value="work charging"/>
            <param name="typicalDuration" value="04:00:00"/>
            <param name="minimalDuration" value="00:15:00"/>
            <param name="priority" value="1"/>
            <param name="scoringThisActivityAtAll" value="true"/>
        </parameterset>

        <!-- school charging -->
        <parameterset type="activityParams">
            <param name="activityType" value="school charging"/>
            <param name="typicalDuration" value="03:00:00"/>
            <param name="minimalDuration" value="00:15:00"/>
            <param name="priority" value="1"/>
            <param name="scoringThisActivityAtAll" value="true"/>
        </parameterset>

        <!-- other charging -->
        <parameterset type="activityParams">
            <param name="activityType" value="other charging"/>
            <param name="typicalDuration" value="00:45:00"/>
            <param name="minimalDuration" value="00:10:00"/>
            <param name="priority" value="1"/>
            <param name="scoringThisActivityAtAll" value="true"/>
        </parameterset>

        <!-- charging failed types -->
        <parameterset type="activityParams">
            <param name="activityType" value="home charging failed"/>
            <param name="typicalDuration" value="00:01:00"/>
            <param name="minimalDuration" value="00:01:00"/>
            <param name="priority" value="1"/>
            <param name="scoringThisActivityAtAll" value="true"/>
        </parameterset>
        <parameterset type="activityParams">
            <param name="activityType" value="work charging failed"/>
            <param name="typicalDuration" value="00:01:00"/>
            <param name="minimalDuration" value="00:01:00"/>
            <param name="priority" value="1"/>
            <param name="scoringThisActivityAtAll" value="true"/>
        </parameterset>
        <parameterset type="activityParams">
            <param name="activityType" value="school charging failed"/>
            <param name="typicalDuration" value="00:01:00"/>
            <param name="minimalDuration" value="00:01:00"/>
            <param name="priority" value="1"/>
            <param name="scoringThisActivityAtAll" value="true"/>
        </parameterset>
        <parameterset type="activityParams">
            <param name="activityType" value="other charging failed"/>
            <param name="typicalDuration" value="00:01:00"/>
            <param name="minimalDuration" value="00:01:00"/>
            <param name="priority" value="1"/>
            <param name="scoringThisActivityAtAll" value="true"/>
        </parameterset>

        <!-- interactions -->
        <parameterset type="activityParams">
            <param name="activityType" value="car interaction"/>
            <param name="typicalDuration" value="00:00:00"/>
            <param name="priority" value="1"/>
            <param name="scoringThisActivityAtAll" value="false"/>
        </parameterset>
        <parameterset type="activityParams">
            <param name="activityType" value="pt interaction"/>
            <param name="typicalDuration" value="00:00:00"/>
            <param name="priority" value="1"/>
            <param name="scoringThisActivityAtAll" value="false"/>
        </parameterset>

    </parameterset>
</module>

<!-- ======================================================================= -->
<!-- Strategy (Replanning) — Baseline: NO en-route charging                  -->
<!-- Only ChangeChargingBehaviour + SelectExpBeta                             -->
<!-- ======================================================================= -->
<module name="strategy">
    <param name="fractionOfIterationsToDisableInnovation" value="0.80"/>
    <param name="maxAgentPlanMemorySize" value="5"/>

    <!-- nonCriticalSOC: exploit + charging mutation -->
    <parameterset type="strategysettings">
        <param name="strategyName" value="SelectExpBeta"/>
        <param name="weight" value="0.6"/>
        <param name="subpopulation" value="nonCriticalSOC"/>
    </parameterset>
    <parameterset type="strategysettings">
        <param name="strategyName" value="ChangeChargingBehaviour"/>
        <param name="weight" value="0.4"/>
        <param name="subpopulation" value="nonCriticalSOC"/>
    </parameterset>

    <!-- criticalSOC: aggressive replanning -->
    <parameterset type="strategysettings">
        <param name="strategyName" value="ChangeChargingBehaviour"/>
        <param name="weight" value="1.0"/>
        <param name="subpopulation" value="criticalSOC"/>
    </parameterset>
</module>

<!-- ======================================================================= -->
<!-- UrbanEV Module — Baseline (Original UrbanEV-v2 parameters)              -->
<!-- Charging cost scoring included (original 8 scoring components)          -->
<!-- No PHEV, no SoC persistence, no reliability, no en-route charging       -->
<!-- ======================================================================= -->
<module name="urban_ev">

    <!-- Core parameters -->
    <param name="parkingSearchRadius" value="1500"/>
    <param name="defaultRangeAnxietyThreshold" value="0.322"/>
    <param name="vehicleTypesFile" value="../input/urbanev_vehicletypes.xml"/>

    <!-- Utility weights (original UrbanEV-v2 values) -->
    <param name="rangeAnxietyUtility" value="-6"/>
    <param name="emptyBatteryUtility" value="-40"/>
    <param name="walkingUtility" value="-2.5"/>
    <param name="homeChargingUtility" value="2.5"/>
    <param name="socDifferenceUtility" value="-4"/>

    <!-- Plan mutation controls -->
    <param name="maxNumberSimultaneousPlanChanges" value="2"/>
    <param name="timeAdjustmentProbability" value="0.2"/>
    <param name="maxTimeFlexibility" value="600"/>

    <!-- Home/work charger generation (from population attributes) -->
    <param name="generateHomeChargersByPercentage" value="false"/>
    <param name="generateWorkChargersByPercentage" value="false"/>
    <param name="defaultHomeChargerPower" value="7.2"/>
    <param name="defaultWorkChargerPower" value="7.2"/>

    <!-- Power-tier pricing (USD/kWh, Maryland rates) — INCLUDED in baseline -->
    <param name="homeChargingCost" value="0.13"/>
    <param name="workChargingCost" value="0.0"/>
    <param name="publicL1Cost" value="0.18"/>
    <param name="publicL2Cost" value="0.25"/>
    <param name="publicDCFCCost" value="0.48"/>
    <param name="dcfcPowerThreshold" value="50.0"/>
    <param name="l2PowerThreshold" value="3.0"/>

    <!-- Monetary utility -->
    <param name="betaMoney" value="-0.05"/>
    <param name="alphaScaleCost" value="1.0"/>

    <!-- Value of time -->
    <param name="baseValueOfTimeFactor" value="0.4"/>
    <param name="queueAnnoyanceFactor" value="2.0"/>
    <param name="detourDisutilityPerHour" value="0.0"/>

    <!-- Agent heterogeneity -->
    <param name="usePersonLevelParams" value="true"/>

    <!-- Smart charging -->
    <param name="enableSmartCharging" value="true"/>
    <param name="alphaScaleTemporal" value="0.5"/>
    <param name="awarenessFactor" value="0.3"/>
    <param name="coincidenceFactor" value="0.7"/>

    <!-- En-route charging DISABLED for baseline -->
    <param name="enableEnRouteCharging" value="false"/>

    <!-- PHEV DISABLED for baseline -->
    <param name="phevMinSocFraction" value="0.15"/>
    <param name="phevGasCostPerLiter" value="0.95"/>
    <param name="phevCSEfficiency" value="0.30"/>

    <!-- SoC persistence DISABLED for baseline -->
    <param name="enableSocPersistence" value="false"/>

    <!-- Workplace charger competition DISABLED for baseline -->
    <param name="workplaceChargerRatio" value="5"/>
    <param name="workplaceClusterRadius" value="500.0"/>

    <!-- Charger reliability DISABLED for baseline -->
    <param name="enableChargerReliability" value="false"/>
    <param name="dcfcChargerUptime" value="1.0"/>
    <param name="l2ChargerUptime" value="1.0"/>

</module>

<!-- ======================================================================= -->
<!-- Link Statistics                                                         -->
<!-- ======================================================================= -->
<module name="linkStats">
    <param name="writeLinkStatsInterval" value="5"/>
    <param name="averageLinkStatsOverIterations" value="5"/>
</module>

<!-- ======================================================================= -->
<!-- Subtour Mode Choice                                                     -->
<!-- ======================================================================= -->
<module name="subtourModeChoice">
    <param name="modes" value="car,walk"/>
    <param name="chainBasedModes" value="car"/>
    <param name="considerCarAvailability" value="true"/>
</module>

<!-- ======================================================================= -->
<!-- Time Allocation Mutator                                                 -->
<!-- ======================================================================= -->
<module name="TimeAllocationMutator">
    <param name="mutationRange" value="1800"/>
    <param name="mutationAffectsDuration" value="true"/>
</module>

</config>
